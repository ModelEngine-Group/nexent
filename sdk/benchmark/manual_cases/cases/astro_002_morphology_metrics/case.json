{
  "id": "astro_002_morphology_metrics",
  "history_file": "./history.json",
  "queries": [
    "请完整描述论文定义的形态学指标体系，包括三类指标各自的定义、用途和互补关系，以及最终的四层分类方案。",
    "如果一个观测者在某条恒星流中发现了一个约3°宽的间隙和一个小spur，仅凭光度形态学能否判断这些特征是暗子晕引起的还是宿主势场引起的？为什么？",
    "论文的形态指标有哪些保守性设计？这些设计如何影响对实际观测的预测？"
  ],
  "probes": [
    {
      "question": "D_global和D_peak分别回答什么不同的问题？它们为什么互补？",
      "must_contain_any": [
        "整体有多乱",
        "有没有突出局部特征",
        "overall",
        "localized",
        "全局扰动",
        "局部偏离"
      ]
    },
    {
      "question": "为什么选择Wasserstein距离而非KS检验来量化截面与高斯的偏离？Wasserstein对什么更敏感？",
      "must_contain_any": [
        "对尾部敏感",
        "对称",
        "小样本稳定",
        "shape",
        "位置和形状"
      ]
    },
    {
      "question": "流坐标框架的最优投影对指标的保守性有什么影响？为什么这是一个下限？",
      "must_contain_any": [
        "下限",
        "保守",
        "投影掉",
        "固定视角",
        "underestimate"
      ]
    },
    {
      "question": "论文的形态指标体系有什么主要盲区？为什么运动学信息能弥补？",
      "must_contain_any": [
        "视线方向",
        "运动学",
        "kinematic",
        "投影",
        "分辨率"
      ]
    },
    {
      "question": "C_w与D_global测的是否是同一种复杂性？一条流能否D_global高但C_w低？为什么？",
      "must_contain_any": [
        "不同",
        "均匀变宽",
        "不同物理",
        "宽度变化",
        "截面扰动"
      ]
    }
  ],
  "summary_checks": [
    {
      "description": "D_global vs D_peak distinction",
      "must_contain_any": [
        "overall",
        "global",
        "peak",
        "localized",
        "全局",
        "局部"
      ]
    },
    {
      "description": "Optimal projection conservatism",
      "must_contain_any": [
        "下限",
        "保守",
        "lower bound",
        "conservative"
      ]
    },
    {
      "description": "Number of bins for off-track analysis",
      "must_contain": [
        "8"
      ]
    },
    {
      "description": "Smooth tier D_global threshold",
      "must_contain": [
        "1"
      ]
    },
    {
      "description": "Smooth+Feature D_peak threshold",
      "must_contain": [
        "2"
      ]
    },
    {
      "description": "Smooth fraction percentage",
      "must_contain": [
        "26"
      ]
    },
    {
      "description": "Messy fraction percentage",
      "must_contain": [
        "34"
      ]
    },
    {
      "description": "KDE bandwidth in degrees",
      "must_contain": [
        "0.25"
      ]
    },
    {
