{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexent.dev/contracts/nl2agent-card.schema.json",
  "title": "NL2AGENT card payloads",
  "$defs": {
    "positiveInteger": { "type": "integer", "minimum": 1 },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "requirements_summary": {
      "type": "object",
      "required": [
        "goal",
        "audience_or_scenario",
        "primary_input",
        "expected_output",
        "key_constraints"
      ],
      "properties": {
        "agent_id": { "$ref": "#/$defs/positiveInteger" },
        "goal": { "$ref": "#/$defs/nonEmptyString" },
        "audience_or_scenario": { "$ref": "#/$defs/nonEmptyString" },
        "primary_input": { "$ref": "#/$defs/nonEmptyString" },
        "expected_output": { "$ref": "#/$defs/nonEmptyString" },
        "key_constraints": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": true
    },
    "model_selection": {
      "type": "object",
      "properties": { "agent_id": { "$ref": "#/$defs/positiveInteger" } },
      "additionalProperties": true
    },
    "localTool": {
      "type": "object",
      "required": ["tool_id", "name"],
      "properties": {
        "tool_id": { "$ref": "#/$defs/positiveInteger" },
        "name": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": true
    },
    "localSkill": {
      "type": "object",
      "required": ["skill_id", "name"],
      "properties": {
        "skill_id": { "$ref": "#/$defs/positiveInteger" },
        "name": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": true
    },
    "local_resources": {
      "type": "object",
      "required": ["recommendation_batch_id", "tools", "skills"],
      "properties": {
        "agent_id": { "$ref": "#/$defs/positiveInteger" },
        "recommendation_batch_id": { "$ref": "#/$defs/nonEmptyString" },
        "tools": { "type": "array", "items": { "$ref": "#/$defs/localTool" } },
        "skills": { "type": "array", "items": { "$ref": "#/$defs/localSkill" } }
      },
      "additionalProperties": true
    },
    "mcpInstallOption": {
      "type": "object",
      "required": ["option_id", "type"],
      "properties": {
        "option_id": { "$ref": "#/$defs/nonEmptyString" },
        "type": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": true
    },
    "mcpItem": {
      "type": "object",
      "required": ["recommendation_id", "name", "install_options"],
      "properties": {
        "agent_id": { "$ref": "#/$defs/positiveInteger" },
        "recommendation_id": { "$ref": "#/$defs/nonEmptyString" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "install_options": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/mcpInstallOption" }
        }
      },
      "additionalProperties": true
    },
    "web_mcp": {
      "oneOf": [
        {
          "type": "object",
          "required": ["recommendation_batch_id", "items"],
          "properties": {
            "agent_id": { "$ref": "#/$defs/positiveInteger" },
            "recommendation_batch_id": { "$ref": "#/$defs/nonEmptyString" },
            "items": { "type": "array", "items": { "$ref": "#/$defs/mcpItem" } }
          },
          "additionalProperties": true
        },
        {
          "allOf": [
            { "$ref": "#/$defs/mcpItem" },
            {
              "type": "object",
              "required": ["recommendation_batch_id"],
              "properties": {
                "recommendation_batch_id": { "$ref": "#/$defs/nonEmptyString" }
              }
            }
          ]
        }
      ]
    },
    "skillItem": {
      "type": "object",
      "properties": {
        "agent_id": { "$ref": "#/$defs/positiveInteger" },
        "skill_id": { "$ref": "#/$defs/positiveInteger" },
        "skill_name": { "$ref": "#/$defs/nonEmptyString" },
        "name": { "$ref": "#/$defs/nonEmptyString" }
      },
      "allOf": [
        {
          "anyOf": [{ "required": ["name"] }, { "required": ["skill_name"] }]
        },
        {
          "anyOf": [
            { "required": ["skill_id"] },
            { "required": ["skill_name"] }
          ]
        }
      ],
      "additionalProperties": true
    },
    "web_skill": {
      "oneOf": [
        {
          "type": "object",
          "required": ["recommendation_batch_id", "items"],
          "properties": {
            "agent_id": { "$ref": "#/$defs/positiveInteger" },
            "recommendation_batch_id": { "$ref": "#/$defs/nonEmptyString" },
            "items": {
              "type": "array",
              "items": { "$ref": "#/$defs/skillItem" }
            }
          },
          "additionalProperties": true
        },
        {
          "allOf": [
            { "$ref": "#/$defs/skillItem" },
            {
              "type": "object",
              "required": ["recommendation_batch_id"],
              "properties": {
                "recommendation_batch_id": { "$ref": "#/$defs/nonEmptyString" }
              }
            }
          ]
        }
      ]
    },
    "agent_identity": {
      "type": "object",
      "required": ["display_name"],
      "properties": {
        "agent_id": { "$ref": "#/$defs/positiveInteger" },
        "display_name": { "type": "string", "minLength": 1, "maxLength": 50 }
      },
      "additionalProperties": true
    },
    "final_review": {
      "type": "object",
      "required": ["business_description", "duty_prompt", "greeting_message"],
      "properties": {
        "agent_id": { "$ref": "#/$defs/positiveInteger" },
        "business_description": { "$ref": "#/$defs/nonEmptyString" },
        "duty_prompt": { "$ref": "#/$defs/nonEmptyString" },
        "greeting_message": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": true
    }
  }
}
